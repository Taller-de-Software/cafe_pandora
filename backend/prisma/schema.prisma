// ============================================================
// schema.prisma — Café Pandora
// Versión final
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Rol {
  administrador
  mesero
}

enum EstadoMesa {
  vacia
  ocupada
  por_pagar
  reservada
}

enum EstadoPedido {
  recibido
  pendiente
  hecho
  finalizado
  cancelado
}

enum TipoMovimientoCaja {
  entrada
  salida
}

// ============================================================
// USUARIO
// ============================================================

model Usuario {
  id     Int     @id @default(autoincrement())
  rol    Rol     @unique
  pin    String?

  pedidos Pedido[]

  @@map("usuarios")
}

// ============================================================
// CATEGORIA
// ============================================================

model Categoria {
  id            Int            @id @default(autoincrement())
  nombre        String         @unique
  subcategorias Subcategoria[]
  productos     Producto[]

  @@map("categorias")
}

// ============================================================
// SUBCATEGORIA
// ============================================================

model Subcategoria {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique
  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  productos   Producto[]

  @@map("subcategorias")
}

// ============================================================
// METODO PAGO
// ============================================================

model MetodoPago {
  id      Int     @id @default(autoincrement())
  nombre  String  @unique
  entidad String?

  facturas Factura[]

  @@map("metodos_pago")
}

// ============================================================
// PRODUCTO
// ============================================================

model Producto {
  id                  Int           @id @default(autoincrement())
  nombre              String
  descripcion         String?
  precio              Float
  imagenUrl           String?
  requierePreparacion Boolean       @default(false)
  habilitado          Boolean       @default(true)
  categoriaId         Int
  categoria           Categoria     @relation(fields: [categoriaId], references: [id])
  subcategoriaId      Int?
  subcategoria        Subcategoria? @relation(fields: [subcategoriaId], references: [id])

  detallesPedido DetallePedido[]

  @@map("productos")
}

// ============================================================
// MESA
// ============================================================

model Mesa {
  id            Int        @id @default(autoincrement())
  nombre        String     @unique
  ubicacion     String
  estado        EstadoMesa @default(vacia)
  personalizada Boolean    @default(false)

  pedidos       Pedido[]    @relation("MesaActual")
  pedidosOrigen Pedido[]    @relation("MesaOrigen")
  unionMesas    UnionMesa[]

  @@map("mesas")
}

// ============================================================
// PEDIDO
// ============================================================

model Pedido {
  id           Int          @id @default(autoincrement())
  turno        Int
  estado       EstadoPedido @default(recibido)
  total        Float?
  mesaId       Int
  mesa         Mesa         @relation("MesaActual", fields: [mesaId], references: [id])
  mesaOrigenId Int?
  mesaOrigen   Mesa?        @relation("MesaOrigen", fields: [mesaOrigenId], references: [id])
  usuarioId    Int
  usuario      Usuario      @relation(fields: [usuarioId], references: [id])

  creadoEn     DateTime  @default(now())
  pendienteEn  DateTime?
  hechoEn      DateTime?
  finalizadoEn DateTime?
  canceladoEn  DateTime?

  detalles   DetallePedido[]
  factura    Factura?
  unionMesas UnionMesa[]

  @@map("pedidos")
}

// ============================================================
// DETALLE PEDIDO
// ============================================================

model DetallePedido {
  id             Int      @id @default(autoincrement())
  cantidad       Int
  precioUnitario Float
  notas          String?
  pedidoId       Int
  pedido         Pedido   @relation(fields: [pedidoId], references: [id])
  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id])

  @@map("detalles_pedido")
}

// ============================================================
// FACTURA
// ============================================================

model Factura {
  id              Int        @id @default(autoincrement())
  subtotal        Float
  impuestoConsumo Float      @default(0)
  total           Float
  creadoEn        DateTime   @default(now())
  pedidoId        Int        @unique
  pedido          Pedido     @relation(fields: [pedidoId], references: [id])
  metodoPagoId    Int
  metodoPago      MetodoPago @relation(fields: [metodoPagoId], references: [id])
  cajaSesionId    Int
  cajaSesion      CajaSesion @relation(fields: [cajaSesionId], references: [id])

  @@map("facturas")
}

// ============================================================
// UNION MESA
// ============================================================

model UnionMesa {
  id       Int    @id @default(autoincrement())
  mesaId   Int
  mesa     Mesa   @relation(fields: [mesaId], references: [id])
  pedidoId Int
  pedido   Pedido @relation(fields: [pedidoId], references: [id])

  @@map("union_mesas")
}

// ============================================================
// CAJA SESION
// ============================================================

model CajaSesion {
  id           Int       @id @default(autoincrement())
  baseInicial  Float
  totalVentas  Float     @default(0)
  totalEgresos Float     @default(0)
  totalEnCaja  Float     @default(0)
  netoCajon    Float     @default(0)
  apertura     DateTime  @default(now())
  cierre       DateTime?

  retiros  RetiroCaja[]
  facturas Factura[]

  @@map("caja_sesiones")
}

// ============================================================
// RETIRO CAJA
// ============================================================

model RetiroCaja {
  id           Int                @id @default(autoincrement())
  tipo         TipoMovimientoCaja
  monto        Float
  retiradoEn   DateTime           @default(now())
  cajaSesionId Int
  cajaSesion   CajaSesion         @relation(fields: [cajaSesionId], references: [id])

  @@map("retiros_caja")
}
