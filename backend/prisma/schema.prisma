generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USUARIOS
// ─────────────────────────────────────────
model Usuario {
  id     Int  @id @default(autoincrement())
  nombre String
  rol    Rol  @unique
  pin    String?

  pedidos      Pedido[]
  cajaSesiones CajaSesion[]
  retirosCaja  RetiroCaja[]

  @@map("usuarios")
}

enum Rol {
  administrador
  mesero
}

// ─────────────────────────────────────────
// MESAS
// ─────────────────────────────────────────
model Mesa {
  id             Int        @id @default(autoincrement())
  numero         String     @unique
  ubicacion      String
  capacidad      Int        @default(4)
  estado         EstadoMesa @default(vacia)
  personalizada  Boolean    @default(false)
  meseroActualId Int?
  nombreCliente  String?
  fechaReserva   String?
  horaReserva    String?
  ocupadaDesde   DateTime?

  pedidos       Pedido[] @relation("MesaActual")
  pedidosOrigen Pedido[] @relation("MesaOrigen")
  unionMesas    UnionMesa[]

  @@map("mesas")
}

enum EstadoMesa {
  vacia
  ocupada
  por_pagar
  reservada
}

// ─────────────────────────────────────────
// CATEGORIAS
// ─────────────────────────────────────────
model Categoria {
  id     Int    @id @default(autoincrement())
  nombre String @unique

  productos Producto[]

  @@map("categorias")
}

// ─────────────────────────────────────────
// PRODUCTOS
// ─────────────────────────────────────────
model Producto {
  id                  Int     @id @default(autoincrement())
  nombre              String
  descripcion         String?
  precio              Float
  imagenUrl           String?
  disponible          Boolean @default(true)
  requierePreparacion Boolean @default(false)

  categoriaId Int
  categoria   Categoria @relation(fields: [categoriaId], references: [id])

  detallesPedido DetallePedido[]

  @@map("productos")
}

// ─────────────────────────────────────────
// PEDIDOS
// ─────────────────────────────────────────
model Pedido {
  id     Int          @id @default(autoincrement())
  turno  Int
  estado EstadoPedido @default(espera)
  tipo   String?
  total  Float?

  mesaId       Int
  mesa         Mesa @relation("MesaActual", fields: [mesaId], references: [id])
  mesaOrigenId Int?
  mesaOrigen   Mesa? @relation("MesaOrigen", fields: [mesaOrigenId], references: [id])

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  creadoEn       DateTime @default(now())
  esperaEn       DateTime?
  preparacionEn  DateTime?
  listoEn        DateTime?
  cajaEn         DateTime?
  facturadoEn    DateTime?
  canceladoEn    DateTime?

  detalles   DetallePedido[]
  factura    Factura?
  unionMesas UnionMesa[]

  @@map("pedidos")
}

enum EstadoPedido {
  espera
  preparacion
  listo
  caja
  facturado
  cancelado
}

// ─────────────────────────────────────────
// DETALLE PEDIDO
// ─────────────────────────────────────────
model DetallePedido {
  id             Int    @id @default(autoincrement())
  cantidad       Int
  precioUnitario Float
  notas          String?

  pedidoId   Int
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  productoId Int
  producto   Producto @relation(fields: [productoId], references: [id])

  @@map("detalle_pedido")
}

// ─────────────────────────────────────────
// FACTURAS
// ─────────────────────────────────────────
model Factura {
  id              Int        @id @default(autoincrement())
  subtotal        Float
  impuestoConsumo Boolean    @default(false)
  total           Float
  cambio          Float?
  metodoPago      MetodoPago
  entidadBancaria String?
  pagadoEn        DateTime   @default(now())

  pedidoId Int    @unique
  pedido   Pedido @relation(fields: [pedidoId], references: [id])

  unionMesas UnionMesa[]

  @@map("facturas")
}

enum MetodoPago {
  efectivo
  transferencia
  tarjeta
}

// ─────────────────────────────────────────
// UNION DE MESAS
// ─────────────────────────────────────────
model UnionMesa {
  id       Int      @id @default(autoincrement())
  unidoEn  DateTime @default(now())

  facturaId Int
  factura   Factura @relation(fields: [facturaId], references: [id])
  pedidoId  Int
  pedido    Pedido  @relation(fields: [pedidoId], references: [id])
  mesaId    Int
  mesa      Mesa    @relation(fields: [mesaId], references: [id])

  @@map("union_mesas")
}

// ─────────────────────────────────────────
// CAJA SESIONES
// ─────────────────────────────────────────
model CajaSesion {
  id           Int      @id @default(autoincrement())
  baseInicial  Float
  totalVentas  Float    @default(0)
  totalEgresos Float    @default(0)
  totalEnCaja  Float    @default(0)
  netoCajon    Float    @default(0)
  apertura     DateTime @default(now())
  cierre       DateTime?

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  retiros RetiroCaja[]

  @@map("caja_sesiones")
}

// ─────────────────────────────────────────
// RETIROS DE CAJA
// ─────────────────────────────────────────
model RetiroCaja {
  id          Int      @id @default(autoincrement())
  descripcion String
  categoria   String   @default("otro")
  monto       Float
  retiradoEn  DateTime @default(now())

  cajaSesionId Int
  cajaSesion   CajaSesion @relation(fields: [cajaSesionId], references: [id])
  usuarioId    Int
  usuario      Usuario @relation(fields: [usuarioId], references: [id])

  @@map("retiros_caja")
}
